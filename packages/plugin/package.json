{
  "name": "vite-plugin-mock-mini",
  "version": "1.0.1",
  "description": "A lightweight mock server plugin for Vite",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "pack": "npm pack",
    "publish": "unbuild && npm publish --registry=https://registry.npmjs.org"
  },
  "keywords": [
    "vite",
    "mock",
    "plugin"
  ],
  "author": "rwx",
  "license": "MIT",
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.2",
    "unbuild": "^3.2.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@types/qs": "^6.9.18",
    "body-parser": "^1.20.2",
    "bundle-require": "^5.1.0",
    "chokidar": "^3.5.3",
    "fast-glob": "^3.3.0",
    "path-to-regexp": "^6.2.1",
    "qs": "^6.14.0"
  }
}
